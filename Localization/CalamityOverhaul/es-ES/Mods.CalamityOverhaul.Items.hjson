		ItemLegendOnMouseLang: Pulsa 'Shift' para escuchar la historia...
	}
}

RMagicConch: {
	DontUseMagicConch: Una criatura poderosa te está observando...

	RMagicConch: {
		DontUseMagicConch: Una criatura poderosa te está observando...
		DisplayName: Caracola mágica
		Tooltip: Escucha con atención y oirás el océano
	}
}

GraniteTome: {
	DisplayName: Tomo de granito
	Tooltip:
		'''
		Invoca un orbe lento y teledirigido de energía de granito
		Se hace añicos en fragmentos de cristal buscadores al impactar
		'''
}

GraniteFlower: {
	DisplayName: Flor de granito
	Tooltip:
		'''
		Dispara una semilla de cristal que florece en una flor de energía persistente
		La flor pulsa varias veces, rociando pétalos de cristal a su alrededor
		'''
}

GraniteThrowingKnife: {
	DisplayName: Cuchillo arrojadizo de granito
	Tooltip:
		'''
		Lanza un cuchillo perforante que deja una estela de energía cristalina
		Se hace añicos en fragmentos de cristal en su último golpe o contra el terreno
		'''
}

GraniteWalkingBoots: {
	DisplayName: Botas andariegas de granito
	Tooltip:
		'''
		Aumenta enormemente la velocidad de carrera y la aceleración
		Crepita con chispas azules a máxima velocidad
		'''
}

MarbleClub: {
	DisplayName: Garrote de mármol
	Tooltip:
		'''
		Un golpe lento y pesado con un retroceso aplastante
		Puede petrificar a los enemigos, ralentizándolos brevemente
		El primer impacto de cada golpe desata una onda de choque de mármol
		'''
}

MarbleHuntingKnife: {
	DisplayName: Cuchillo de caza de mármol
	Tooltip:
		'''
		Ataques de tajo veloces
		Cada tercer golpe es un remate más amplio que rocía fragmentos de mármol
		'''
}

MarbleDisc: {
	DisplayName: Disco de mármol
	Tooltip:
		'''
		Lanza un disco giratorio que rebota entre enemigos y paredes
		Luego regresa curvándose a tu mano; pueden volar hasta dos a la vez
		'''
}

MarblePebble: {
	DisplayName: Guijarro de mármol
	Tooltip:
		'''
		Una piedra de honda inagotable, veloz y propensa a golpes críticos
		Inflige mucho más daño a los enemigos con mucha vida máxima
		Rebota una vez en el suelo
		'''
}

MarbleShield: {
	DisplayName: Égida de mármol
	Tooltip:
		'''
		Aumenta la defensa y la resistencia al retroceso
		Mantiene una guardia de piedra regenerable que absorbe un golpe entrante, estallando en fragmentos
		Prepárate para un bloqueo perfecto que refleja los proyectiles
		'''
}

MarbleBalloon: {
	DisplayName: Globo de mármol
