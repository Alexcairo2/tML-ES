	DisplayName: Lingote de estrella de neutrones
	Tooltip: El peso de todo, concentrado en la yema de los dedos.
}

InfinityCatalyst: {
	DisplayName: Catalizador Infinito
	Tooltip: Tu codicia está a punto de alcanzar su punto máximo.
}

