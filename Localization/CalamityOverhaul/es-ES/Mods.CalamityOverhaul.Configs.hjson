CWRServerConfig: {
	DisplayName: Configuración de contenido

	WeaponOverhaul: {
		Label: Overhaul en armas
		Tooltip:
			'''
			Al activarlo, se modificarán la mayoría de las armas.
			[c/FF0000:¡Para disfrutar al máximo el contenido de Calamity Overhaul, actívalo!]
			'''
	}

	ScreenVibration: {
		Label: Efecto de vibración de pantalla en ataques especiales de armas
		Tooltip: Si se activa, al realizar algunos ataques, la pantalla vibrará, lo que podría intensificar la sensación de impacto.
	}

	MurasamaSpaceFragmentationBool: {
		Label: Efecto de fragmentación de pantalla en el movimiento final de Murasama
		Tooltip:
			'''
			Activado por defecto, el movimiento final de Murasama producirá efectos de fragmentación de pantalla para intensificar la sensación de impacto.
			Desactivarlo deshabilitará estos efectos; puedes configurarlo según tu preferencia.
			'''
	}

	DomainConciseDisplay: {
		Label: Dominio en modo minimalista
		Tooltip: Desactivado por defecto. Al activarlo, se ocultan la mayoría de efectos visuales dentro del dominio.
	}

	Headers: {
		CWRSystem: Ajustes del sistema Overhaul
		CWRWeapon: Ajustes de armas Overhaul
		CWRUI: Ajustes de interfaz Overhaul
		CWRWorldGen: Ajustes de estructuras Overhaul
	}

	LensEasing: {
		Label: Suavizado de la cámara
		Tooltip: Al habilitar, los movimientos rápidos a larga distancia suavizarán la cámara, evitando la sensación de desajuste por moverse demasiado rápido.
	}

	BiologyOverhaul: {
		Label: Reforma biológica[c/06e33f:(experimental)]
		Tooltip:
			'''
			[c/c20909:Incompleto]
			Activado por defecto, modifica la IA de algunas criaturas, como la de los jefes en Modo Muerte.
			Esto puede aumentar drásticamente la dificultad del juego; se puede elegir desactivarlo según las preferencias personales.
			'''
	}

	MuraUIStyleType: {
		Label: Selección de estilo de UI de Murasama
		Tooltip:
			'''
			Estilo 1: Elegante - Flotante sobre la cabeza
			Estilo 2: Elegante - Compacto
			Estilo 3: Clásico - Flotante sobre la cabeza
			Estilo 4: Clásico - Compacto
			Estilo 5: Oculto
			'''
	}

	MuraPosStyleType: {
		Label: Selección de posición de UI de Murasama
		Tooltip:
			'''
			Preajuste 1: Abajo a la derecha
			Preajuste 2: Abajo a la izquierda
			Preajuste 3: Arriba
			'''
	}

	QuestLog: {
		Label: Guía del diario de misiones
		Tooltip:
			'''
			Al activarlo, el diario de misiones te guiará durante la partida
			Puedes abrir la interfaz con el objeto diario, desde el inventario o con un atajo
			Activado por defecto. Al desactivarlo, desaparece toda la guía de misiones
			'''
	}

	DialogueBox_Scale_Value: {
		Label: Escala del cuadro de diálogo
		Tooltip: Ajusta el tamaño general del cuadro de diálogo
	}

	GenWindGrivenGenerator: {
		Label: Generar aerogeneradores
		Tooltip: Coloca estructuras de generadores eólicos por el mundo
	}

	GenWGGCollector: {
		Label: Generar puestos de chatarreros
		Tooltip: Genera al azar estructuras hostiles de chatarreros. Solo tiene efecto en mundos legendarios
	}

	GenJunkmanBase: {
		Label: Generar base del chatarrero
		Tooltip: Genera una base fortificada de chatarreros en páramos o bajo tierra
	}

	GenRocketHut: {
		Label: Generar cabaña del cohete
		Tooltip: Genera una cabaña misteriosa con piezas de cohete o reliquias tecnológicas
	}

	GenSylvanOutpost: {
		Label: Generar puesto silvano
		Tooltip: Genera puestos de avanzada de elfos o guardianes del bosque en lo profundo del bosque
	}

	ConfigChangePrefix: Usuario
	ConfigChangeSuffix: Se ha modificado la configuración del servidor
}
