QuestNode: {
	FirstQuest: {
		DisplayName: ¡Bienvenido al mundo de Calamity!
		Description: El comienzo del viaje
		DetailedDescription: Toda leyenda empieza en lo humilde. Reclama tu equipo inicial y prepárate para un mundo de dioses y monstruos.
		QuestObjective.Description: Clic izquierdo para reclamar objetos iniciales
	}

	MiningQuest: {
		DisplayName: Fundamentos de minería
		Description: Obtén 10 {0}
		DetailedDescription: El subsuelo guarda riqueza infinita; primero necesitamos metales básicos para herramientas.
	}

	MiningQuestII: {
		DisplayName: Edad del hierro
		Description: Recolecta 50 {0}
		DetailedDescription: El cobre es demasiado blando; necesitamos metales más duros. Baja más para encontrar vetas de hierro.
	}

	MiningQuestIII: {
		DisplayName: Fiebre del oro
		Description: Recolecta 100 {0}
		DetailedDescription: El oro no es solo moneda: maneja bien la magia y es dúctil; más blando que el hierro, pero clave para equipo avanzado.
	}

	BrimstoneElementalQuest: {
		DisplayName: Elemental de Azufre
		Description: Derrota al elemental de azufre
		DetailedDescription: En las ruinas del risco de azufre, despierta y vence al espíritu elemental dormido; cuidado con su infierno de proyectiles.
	}

	CalamitasCloneQuest: {
		DisplayName: Clon de Calamitas
		Description: Derrota al Clon de Calamitas
		DetailedDescription: Un clon lleno de odio y destrucción; véncelo para demostrar que mereces enfrentar a la verdadera bruja.
	}

	CrabulonQuest: {
		DisplayName: Crabulon
		Description: Derrota a Crabulon
		DetailedDescription: En el subsuelo fúngico acecha un cangrejo gigante infestado; sus esporas son muy peligrosas.
	}

	CryogenQuest: {
		DisplayName: Cryogen
		Description: Derrota a Cryogen
		DetailedDescription: El antiguo archimago del cosmos está sellado en hielo eterno; libéralo y véncelo.
	}

	DesertScourgeQuest: {
		DisplayName: Azote Desértico
		Description: Derrota al azote del desierto
		DetailedDescription: El antiguo tirano de los mares ahora agoniza en el desierto seco; cuidado con sus mandíbulas y secuaces.
	}

	EaterofWorldsQuest: {
		DisplayName: Devoramundos / Cerebro de Cthulhu
		Description: Derrota al jefe de la Corrupción o del Carmesí
		QuestObjective.Description: Derrota al Devoramundos o al Cerebro de Cthulhu
		DetailedDescription: El mal se extiende; entra en la herida del mundo y elimina al gusano o al cerebro vil.
	}

	EyeofCthulhuQuest: {
		DisplayName: Ojo de Cthulhu
		Description: Derrota al Ojo de Cthulhu
		DetailedDescription: Mientras sientas esa mirada maligna, aparecerá; es tu primera prueba de verdad.
	}

	GolemQuest: {
		DisplayName: Gólem
		Description: Derrota al Gólem
		DetailedDescription: En el templo de la jungla yace una máquina de guerra antigua; cuidado con láseres y puños.
	}

	HiveMindQuest: {
		DisplayName: La Mente Colmena / La Colmena Perforadora
		Description: Derrota al dios del bioma maligno
		QuestObjective.Description: Derrota a La Mente de la Colmena o a La Colmena Perforadora
		DetailedDescription: Son la conciencia de la Corrupción y el Carmesí hecha carne; si no caen, la tierra no tendrá paz.
	}

	KingSlimeQuest: {
		DisplayName: Rey Slime
		Description: Derrota al Rey Slime
		DetailedDescription: El rey de los gelatinosos; parece cómico, pero no dejes que su tamaño te aplaste.
	}

	LunaticCultistQuest: {
		DisplayName: Cultista Lunático
		Description: Derrota al cultista lunático
		DetailedDescription: En la entrada de la mazmorra, fanáticos intentan evitar o provocar el apocalipsis; detén el ritual.
	}

	MechanicalBossesQuest: {
		DisplayName: Jefes Mecánicos
		Description: Derrota a todos los jefes mecánicos
		QuestObjective.Description: Derrota a todos los jefes mecánicos
		DetailedDescription: Primeras creaciones de Draedon que imitan órganos de Cthulhu; solo al vencerlos el mundo renacerá.
	}

	MoonLordQuest: {
		DisplayName: Señor de la Luna
		Description: Derrota al Señor de la Luna
		DetailedDescription: La mente detrás de todo, el terror del lado oscuro de la luna; acaba con esta pesadilla.
	}

	PlaguebringerGoliathQuest: {
		DisplayName: El Goliat Portador de la Plaga
		Description: Derrota al Goliat Portador de la Plaga
		DetailedDescription: Una abeja reina modificada por un nanovirus; mortal y cargada de peste.
	}

	PlanteraQuest: {
		DisplayName: Plantera
		Description: Derrota a Plantera
		DetailedDescription: En lo profundo de la jungla duerme una flor devoradora; rompe el bulbo y enfréntate a su furia.
	}

	SkeletronQuest: {
		DisplayName: Esqueletrón
		Description: Derrota a Esqueletrón
		DetailedDescription: Solo venciendo a este anciano maldito podrás entrar con seguridad en la mazmorra.
	}

	SlimeGodQuest: {
		DisplayName: El Dios Slime
		Description: Derrota al Dios Slime
		DetailedDescription: La cima de la especie slime, un dios antiguo y voraz; cuidado con sus avatares combinados.
	}

	WallofFleshQuest: {
		DisplayName: Muro carnoso
		Description: Derrota a Muro carnoso
		DetailedDescription: El guardián del mundo. Arroja el muñeco vudú del guía a la lava para liberar a la antigua deidad de este mundo y abrir el modo difícil.
	}

	CeaselessVoidQuest: {
		DisplayName: Vacío Incesante
		Description: Derrota al Vacío Incesante
		DetailedDescription: Centinela del Devorador de Dioses, espejo del vacío de otra dimensión.
	}

	DevourerofGodsQuest: {
		DisplayName: Devorador de Dioses
		Description: Derrota al Devorador de Dioses
		DetailedDescription: Una serpiente cósmica hambrienta de divinidad; combátela en el vacío sin dejar que te trague.
	}

	DragonfollyQuest: {
		DisplayName: Dragonfolly
		Description: Derrota a Dragonfolly
		DetailedDescription: Un fallido clon de Yharon, un pseudodragón loco y electrizado.
	}

	ExoMechsQuest: {
		DisplayName: Exo Mecánicos
		Description: Derrota a los Exo Mecánicos
		DetailedDescription: Las obras maestras de Draedon, cénit de la tecnología terrariana; sobrevive a la función perfecta.
	}

	OldDukeQuest: {
		DisplayName: El Viejo Duque
		Description: Derrota a El Viejo Duque
		DetailedDescription: El antiguo señor de las profundidades del Mar de Azufre; cuidado con su vapor tóxico.
	}

	PolterghastQuest: {
		DisplayName: Polterghast
		Description: Derrota a Polterghast
		DetailedDescription: Almas vengativas de la mazmorra reunidas en un monstruo; calma su furia.
	}

	PrimordialWyrmQuest: {
		DisplayName: Gusano Primordial
		Description: Derrota al Gusano Primordial
		DetailedDescription: Guardián del fondo del abismo, más antiguo que los dioses; no lo molestes sin necesidad.
	}

	ProfanedGuardiansQuest: {
		DisplayName: Guardianes Profanados
		Description: Derrota a los Guardianes Profanados
		DetailedDescription: Leales guardianes de la Diosa Profanada; derrótalos para debilitar sus defensas.
	}

	ProvidenceQuest: {
		DisplayName: Providencia, la Diosa Profanada
		Description: Derrota a Providencia
		DetailedDescription: Diosa del fuego sagrado y la purificación; desafíala en la Bendición o el Inframundo sin quemarte.
	}

	SignusQuest: {
		DisplayName: Signus, Enviado del Devorador
		Description: Derrota a Signus
		DetailedDescription: Centinela del Devorador de Dioses, asesino sin forma, fantasma del vacío.
	}

	StormWeaverQuest: {
		DisplayName: Tejedor de Tormentas
		Description: Derrota al Tejedor de Tormentas
		DetailedDescription: Centinela del Devorador de Dioses, gusano del cielo que se alimenta de rayos.
	}

	SupremeCalamitasQuest: {
		DisplayName: Calamitas Suprema
		Description: Derrota a Calamitas Suprema
		DetailedDescription: La legendaria Bruja del Azufre; ¿fin del viaje o nuevo comienzo? Prepárate para el infierno de proyectiles.
	}

	YharonQuest: {
		DisplayName: Yharon, Fénix Resplandeciente
		Description: Derrota a Yharon
		DetailedDescription: El fiel compañero del Tirano, dragón con renacer de fénix; prueba del alma.
	}

	BatteryQuest: {
		DisplayName: Almacenamiento de energía
		Description: Fabrica una batería térmica
		DetailedDescription: La electricidad debe almacenarse; las baterías son el primer paso de una red estable.
	}

	HydroelectricQuest: {
		DisplayName: Energía limpia
		Description: Fabrica un generador hidroeléctrico
		DetailedDescription: Aprovecha el agua en movimiento para generar electricidad de forma limpia y sostenible.
	}

	IndustrialStartQuest: {
		DisplayName: Revolución industrial
		Description: Fabrica un generador eólico
		DetailedDescription: Primer paso hacia la automatización: usa el viento para mover tus máquinas.
	}

	ItemFilterQuest: {
		DisplayName: Clasificación logística
		Description: Fabrica un filtro de objetos
		DetailedDescription: Las líneas automáticas necesitan orden; controla el flujo con filtros.
	}

	MiningMachineQuest: {
		DisplayName: Excavación automática
		Description: Fabrica una máquina minera
		DetailedDescription: Olvida la minería manual; esta máquina devora vetas con eficiencia asombrosa.
	}

	MiningMachineIIQuest: {
		DisplayName: Perforación profunda
		Description: Fabrica una máquina minera MK2
		DetailedDescription: Un núcleo reforzado ofrece velocidad sin igual.
	}

	PipelineQuest: {
		DisplayName: Transmisión de energía
		Description: Fabrica tuberías de energía universal
		DetailedDescription: Las venas entre generadores y máquinas; sin ellas la electricidad no circula.
	}

	TeslaTowerQuest: {
		DisplayName: Torre de tormenta magnética
		Description: Fabrica una torre Tesla
		DetailedDescription: Tecnología de Draedon; transmite energía sin cables y cambia tu diseño eléctrico.
	}

	ThermalPowerQuest: {
		DisplayName: Hora de quemar
		Description: Fabrica un generador térmico
		DetailedDescription: Quema combustible para mucha energía; poco ecológico, pero fiable al principio.
	}

	AnnihilatingUniverseQuest: {
		DisplayName: Aniquilador del universo
		Description: Obtén el «Aniquilador del universo»
		DetailedDescription: Comprime el poder de galaxias en una cuerda de arco; destruye dimensiones, la prueba suprema del arquero.
	}

	AriaofTheCosmosQuest: {
		DisplayName: Aria del cosmos
		Description: Obtén la «Aria del cosmos»
		DetailedDescription: Toca la sinfonía de las estrellas; invoca agujeros negros y cuásares hasta disolver a los enemigos.
	}

	DarkMatterCompressorQuest: {
		DisplayName: Compresor de materia oscura
		Description: Obtén el compresor de materia oscura
		DetailedDescription: Manipula la materia más misteriosa; comprime materia oscura en esferas de alta densidad.
	}

	InfiniteIngotQuest: {
		DisplayName: Lingote infinito
		Description: Forja lingote infinito
		DetailedDescription: Un metal que trasciende la conservación de la masa; piedra angular del poder supremo.
	}

	InfinitePickQuest: {
		DisplayName: Pico infinito
		Description: Obtén un pico infinito
		DetailedDescription: Nada lo detiene; puede minar hasta el lecho rocoso del mundo.
	}

	InfiniteToiletQuest: {
		DisplayName: Retrete infinito
		Description: Obtén retrete infinito
		DetailedDescription: El trono de los dioses; absurdo, pero simboliza un poder supremo.
	}

	InfinityCatalystQuest: {
		DisplayName: Catalizador infinito
		Description: Obtén catalizador infinito
		DetailedDescription: Clave para la reacción infinita; la materia cicla entre aniquilación y renacimiento.
	}

	NeutronBowQuest: {
		DisplayName: Arco de neutrones
		Description: Obtén arco de neutrones
		DetailedDescription: Forjado con fragmentos del núcleo de una estrella de neutrones; cada flecha lleva gravedad colapsada.
	}

	NeutronGlaiveQuest: {
		DisplayName: Guja de neutrones
		Description: Obtén guja de neutrones
		DetailedDescription: Densidad asombrosa; ninguna armadura resiste su tajo.
	}

	NeutronGunQuest: {
		DisplayName: Rifle de neutrones
		Description: Obtén rifle de neutrones
		DetailedDescription: Dispara microflujos de neutrones casi sin resistencia.
	}

	NeutronScytheQuest: {
		DisplayName: Guadaña de neutrones
		Description: Obtén guadaña de neutrones
		DetailedDescription: La herramienta del segador; siega la vida como trigo.
	}

	NeutronStarIngotQuest: {
		DisplayName: Lingote de estrella de neutrones
		Description: Obtén lingote de estrella de neutrones
		DetailedDescription: Uno de los materiales más densos del universo; vibra con fluctuaciones gravitatorias.
	}

	NeutronWandQuest: {
		DisplayName: Varita de neutrones
		Description: Obtén varita de neutrones
		DetailedDescription: Controla la gravedad y deforma el espacio-tiempo.
	}

	PandemoniumQuest: {
		DisplayName: Pandemonium
		Description: Obtén «Pandemonium»
		DetailedDescription: Arma definitiva que fusiona almas y poder calamitoso; llaves del infierno y el abismo.
	}

	RockQuest: {
		DisplayName: Piedra eternita antigua
		Description: Obtén piedra eternita antigua
		DetailedDescription: Una piedra aparentemente común que ha visto innumerables ciclos del Boss Rush; símbolo de perseverancia eterna.
	}

	TerminusQuest: {
		DisplayName: Terminus
		Description: Obtén el Terminus
		DetailedDescription: Llave para iniciar el Boss Rush; contempla la piedra y enfrenta a los seres más fuertes del mundo.
	}

	TransmutationOfMatterQuest: {
		DisplayName: Transmutador de materia
		Description: Obtén transmutador de materia
		DetailedDescription: Alquimia suprema que rompe el intercambio equivalente y crea de la nada.
	}

	HeavenfallLongbowQuest: {
		DisplayName: Arco infinito
		Description: Obtén arco infinito
		DetailedDescription: Un arco que derribó dioses; vuelve al mundo.
	}

	SpearOfLonginusQuest: {
		DisplayName: Lanza de Longino
		Description: Obtén lanza de Longino
		DetailedDescription: La lanza sagrada que perforó a un dios; atraviesa campos y dominios absolutos.
	}

	DragonsWordQuest: {
		DisplayName: Palabra del dragón
		Description: Obtén palabra del dragón
		DetailedDescription: Un dragón solo llora una vez en la vida, al morir.
	}

	RockQuestII: {
		DisplayName: Ciclo de conquista
		Description: Completa el Boss Rush 5 veces y obtén 5 piedras eternita antiguas
		DetailedDescription: Símbolo del verdadero guerrero
	}

	AdventurerQuests: {
		DisplayName: Aventurero
		Description: ¡El mundo es mío!
		QuestObjective.Description: Clic para reclamar
		DetailedDescription: Todo viaje empieza con un paso; calza estas botas y recorre el mundo.
	}

	ExploreDungeon: {
		DisplayName: Mazmorra sombría
		Description: Descubre la entrada de la mazmorra
		QuestObjective.Description: Llega a la mazmorra
		DetailedDescription: Secretos y peligros tras muros malditos; solo los más valientes pisan el reino de los muertos.
	}

	ExploreHell: {
		DisplayName: Abismo infernal
		Description: Desciende al Inframundo
		QuestObjective.Description: Llega al Inframundo
		DetailedDescription: Ríos de lava en lo más profundo; hogar de demonios y fuente de obsidiana y mineral del infierno.
	}

	ExploreJungle: {
		DisplayName: Expedición a la jungla
		Description: Adéntrate en la jungla
		QuestObjective.Description: Llega a la jungla
		DetailedDescription: Un laberinto verde vibrante y mortal; templos antiguos y enjambres de abejas.
	}

	ExploreOcean: {
		DisplayName: Fin del mundo
		Description: Llega al océano
		QuestObjective.Description: Llega al océano
		DetailedDescription: Donde el cielo y el mar se encuentran; naufragios y monstruos bajo el azul profundo.
	}

	ExploreSnow: {
		DisplayName: Tierra helada
		Description: Explora la tundra nevada
		QuestObjective.Description: Llega a la nieve
		DetailedDescription: Permafrost eterno; la vida aquí es más resistente.
	}

	ExploreSpace: {
		DisplayName: Mar de estrellas
		Description: Vuela al espacio
		QuestObjective.Description: Llega al espacio
		DetailedDescription: Libérate de la gravedad y toca las estrellas para ver el mundo entero.
	}

	HellLabSchematic: {
		DisplayName: Esquema del infierno
		Description: Busca el esquema cifrado en el laboratorio de Draedon del Inframundo
		QuestObjective.Description: Obtén el esquema del infierno
		DetailedDescription: Draedon tenía un puesto en el infierno para experimentar con energía geotérmica; el esquema puede desbloquear nuevas armas.
	}

	IceLabSchematic: {
		DisplayName: Código polar
		Description: Busca el esquema cifrado en el laboratorio de Draedon en la nieve
		QuestObjective.Description: Obtén el esquema helado
		DetailedDescription: El frío conserva instrumentos de precisión; baja al laboratorio bajo el hielo.
	}

	JungleLabSchematic: {
		DisplayName: Borrador de la jungla
		Description: Busca el esquema cifrado en el laboratorio de Draedon en la jungla
		QuestObjective.Description: Obtén el esquema de la jungla
		DetailedDescription: La jungla oculta el laboratorio biológico de Draedon sobre plagas y nanovirus.
	}

	PlanetoidLabSchematic: {
		DisplayName: Misterio estelar
		Description: Busca el esquema cifrado en el laboratorio de Draedon en el planetoide
		QuestObjective.Description: Obtén el esquema del planetoide
		DetailedDescription: En la microgravedad de las alturas flota un laboratorio con diseños tempranos de mecánicas estelares.
	}

	SunkenSeaLabSchematic: {
		DisplayName: Mar hundido
		Description: Busca el esquema cifrado en el laboratorio de Draedon del Mar hundido
		QuestObjective.Description: Obtén el esquema del mar hundido
		DetailedDescription: En este mar subterráneo tranquilo, Draedon dejó investigación sobre energía prismática.
	}

	AquaticScourgeQuest: {
		DisplayName: Azote Acuático
		Description: Derrota al Azote Acuático
		DetailedDescription: Antes leviatán pacífico del océano claro, ahora retorcido por el Mar de Azufre; cuidado con cargas y nubes tóxicas.
	}

	QueenSlimeQuest: {
		DisplayName: Reina Slime
		Description: Derrota a la Reina Slime
		DetailedDescription: Emperatriz cristalina de la Bendición; más ágil y letal que su consorte; prepárate para un aluvión espectacular.
	}

	BuildHouse: {
		DisplayName: Maestro constructor
		Description: Construye una casa válida
		QuestObjective.Description: Construye una casa válida
		DetailedDescription: Todos necesitan refugio; con mesa, silla, luz y paredes atraerás al guía y a otros NPC.
	}

	CollectEvilOres: {
		DisplayName: Minerales malignos
		Description: Recolecta minerales malignos
		QuestObjective.Description: Recolecta mineral de demonita o carmesita
		DetailedDescription: Minerales de aura inquietante, fríos y viscosos; esenciales pese a venir de la herida del mundo.
	}

	CollectFallenStars: {
		DisplayName: Coleccionista de estrellas
		Description: Recolecta estrellas fugaces
		QuestObjective.Description: Recolecta estrellas fugaces
		DetailedDescription: Lágrimas del cielo nocturno; aumentan maná y sirven de munición o material mágico.
	}

	CollectGems: {
		DisplayName: Coleccionista de gemas
		Description: Recolecta gemas variadas
		QuestObjective.Description: Recolecta cinco tipos de gemas
		DetailedDescription: Cristales en la roca; decoración y material para bastones y garfios; juntar colores forma un arcoíris.
	}

	CollectHerbs: {
		DisplayName: Aprendiz de hierbas
		Description: Recolecta hierbas variadas
		QuestObjective.Description: Recolecta tres tipos de hierbas
		DetailedDescription: Base de la alquimia; plantas del desierto, la nieve o el infierno; el primer paso del maestro alquimista.
	}

	CollectOres: {
		DisplayName: Recolección de minerales
		Description: Recolecta minerales básicos

		QuestObjective: {
			Description: {
				Iron: Recolecta mineral de hierro o plomo
				Copper: Recolecta mineral de cobre o estaño
			}
		}

		DetailedDescription: La minería es supervivencia; cobre y hierro son el inicio de todo héroe.
	}

	DeepExplorer: {
		DisplayName: Explorador profundo
		Description: Explora todos los biomas principales
		QuestObjective.Description: Completa todas las misiones de exploración
		DetailedDescription: Has recorrido el mundo de las nubes al infierno; el mapa prueba tu valor.
	}

	ExploreCaverns: {
		DisplayName: Profundidades de caverna
		Description: Explora capas más profundas
		QuestObjective.Description: Llega a la capa de cavernas
		DetailedDescription: Sin sol, solo oscuridad y criaturas; aparece lava y más mineral; el abismo te mira.
	}

	ExploreCorruption: {
		DisplayName: Corrupción / Carmesí
		Description: Explora la Corrupción o el Carmesí
		QuestObjective.Description: Entra en la Corrupción o el Carmesí
		DetailedDescription: La tierra está enferma; hay que entrar en la guarida para escamas o muestras de tejido.
	}

	ExploreDesert: {
		DisplayName: Desierto ardiente
		Description: Entra en el desierto
		QuestObjective.Description: Llega al desierto
		DetailedDescription: Sol abrasador y arena dorada; lleva agua o la sequedad te vencerá.
	}

	ExploreFloatingIsland: {
		DisplayName: Islas flotantes
		Description: Encuentra islas en el cielo
		QuestObjective.Description: Llega a una isla flotante
		DetailedDescription: Tesoros sobre las nubes; busca anomalías gravitatorias o construye una torre.
	}

	ExploreGlowingMushroom: {
		DisplayName: Setas luminiscentes
		Description: Encuentra el bioma de setas luminiscentes
		QuestObjective.Description: Llega al bioma de setas luminiscentes
		DetailedDescription: Ecosistema subterráneo de luz azul; hogar de la trufa y bichos extraños.
	}

	ExploreUnderground: {
		DisplayName: Exploración subterránea
		Description: Adéntrate en cuevas
		QuestObjective.Description: Llega al subsuelo
		DetailedDescription: Raspar la superficie no basta; la aventura empieza bajo tierra.
	}

	FindLifeCrystal: {
		DisplayName: Fuente de vida
		Description: Encuentra un cristal de vida
		QuestObjective.Description: Encuentra un cristal de vida
		DetailedDescription: Cristal rojo de vitalidad; úsalo para fortalecer el cuerpo permanentemente.
	}

	FindShadowOrb: {
		DisplayName: Núcleo del mal
		Description: Encuentra un orbe sombrío o corazón carmesí
		QuestObjective.Description: Destruye un orbe sombrío o corazón carmesí
		DetailedDescription: En lo profundo del mal palpita corrupción u orbe; romper tres despertará algo terrible.
	}

	FirstPotion: {
		DisplayName: Introducción a alquimia
		Description: Prepara tu primera poción
		QuestObjective.Description: Prepara cualquier poción
		DetailedDescription: Botella sobre mesa y ya tienes alquimia; mezcla ingredientes y bebe la magia.
	}

	NPCVillage: {
		DisplayName: Aldea próspera
		Description: Atrae a varios NPC
		QuestObjective.Description: Ten cinco NPC
		DetailedDescription: La soledad pesa; con monedas y fuerza llegará gente; construye una comunidad.
	}

