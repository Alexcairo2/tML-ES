TitleLinks: {
	Patreon: Patreon
	Github: Github
}

ExpandedStandard:
	'''
	Desactiva el Modo Eternidad o Masoquista.
	La dificultad del mundo (Experto, Maestro) permanece sin cambios.
	'''
ExpandedEternity:
	'''
	[c/00FFFF:Un nuevo modo por encima de Experto para los veteranos de Terraria. La experiencia Fargo prevista.]
	El mundo debe estar en Modo Experto
	Activa el Modo Masoquista si el mundo está en Modo Maestro o superior
	'''
ExpandedMasochist:
	'''
	[c/33ffbe:Un modo de desafío adicional extremadamente intenso. ¡Se recomienda encarecidamente jugar primero el Modo Eternidad!]
	El mundo debe estar en Modo Maestro o superior
	Activa el Modo Eternidad si el mundo está en Modo Experto
	'''
EternityOption:
	'''
	[c/00FFFF:Un nuevo modo por encima de Experto para los veteranos de Terraria. La experiencia Fargo prevista.]
	Establece la dificultad del mundo en Modo Experto
	'''
MasochistOption:
	'''
	[c/33ffbe:Un modo de desafío adicional extremadamente intenso. ¡Se recomienda encarecidamente jugar primero el Modo Eternidad!]
	Establece la dificultad del mundo en Modo Maestro
	'''
ExpandedFeatures:
	'''
	Las características de Eternidad incluyen:

	-Rediseña jefes y enemigos, haciéndolos más fuertes
	-Activa el botín del Modo Maestro
	-Nuevo botín de objetos exclusivos de Eternidad
	-Deviantt proporciona un paquete inicial y consejos según tu progreso
	-Mejora las estadísticas base y limita la RD del jugador al 75%
	-Los efectos negativos desaparecen más rápido cuando no atacas; no puedes morir por efectos de daño con el tiempo salvo en Modo Masoquista
	-Cambia la funcionalidad y la potencia de ciertos objetos
	'''
MasochistMultiplayer: -En multijugador Masoquista, cada jugador solo puede reaparecer una vez por combate de jefe
