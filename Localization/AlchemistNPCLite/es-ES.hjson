Mods: {
	AlchemistNPCLite: {
		Bestiary: {
			Alchemist: Provee una variedad de pociones utiles, plantas, Champiñones y otro tipo de cosas para vender. ''Lore-wise'' es un viejo amigo/interes amoroso en El Cervecero. actualmente, ''divorciado''.
			Brewer: Provee una varidedad pociones de mejoras para vender. ''Lore-wise'' Es un viejo amigo/interes amoroso por la alquimista. Actualmente, ''Divorciado''.
			Jeweler: Provee una infinita cantidad de diferentes gemas por vender. También puede ayudar con los objetos necesarios para montar una arena, tanto para las sesiones de grindeo como para las peleas contra jefes. ''Lore-wise'' Se puede considerar el hermano gemelo de los comerciantes.
			Musician: Provee una cantidad diferente de cajas musicales para vender a medida de que avanzas. Sin historia real que exista.
			Operator: Provee una varidedad de diferentes materiales para craftear y bolsas del tesoro (Si juegas en Experto+). No es Humana.
			Architect: Provee una varidad de difetentes bloques de construcción y estaciones de crafteo. Experto en decoraciones.
			Tinkerer: Prove una varidedad de accesorios a medida que avanzas. ''Lore-wise'' Es el hermano menor de la Steampunker.
			YoungBrewer: Ofrece una variedad de combinaciones de pociones y frascos para vender. ''Lore-wise'' Es hijo de la alquimista y El Cervecero.
		}

		Common: {
			DayTimeSet: La hora esta configurada para la mañana.
			NightTimeSet: La hora esta configurada para la noche.
			SandstormStarted: La tormenta de arena a comenzado.
			SandstormStopped: Se a parado la tormenta de arena.
			RainStarted: Comenzo a llover.
			RainStopped: A parado de llover.
		}

		#This is what displays during all of an NPC's happiness levels. Note that the localization key for these should always be "TownNPCMood.*NPCName*.*Mood*" or else it won't display properly.
		TownNPCMood: {
			Alchemist: {
				Content: !Me siento Bien!
				NoHome: ¿Tienes alguna vivienda de repuesto? es realmente incomodo hacer pociones sin un techo sobre mi cabeza.
				LoveSpace: Paz y tranquilidad me permiten disfrutar a lo grande!
				FarFromHome: Creo que mi casa estaba por ahi... A menos que me estes llevando a algun lado
				DislikeCrowded: Cuantos más, mejor, y todo eso, pero ya empiezo a sentirme un poco apretada.
				HateCrowded: No puedo estirar las piernas y relajarme sin patear a alguien...
				LikeBiome: Calido y tranquilo ¿Qué mejor para preparar pociones?
				LoveBiome: Este lugar me recuerda a mis viejos dias cuando entrenaba con mi amigo.
				DislikeBiome: Hace mucho frio aqui... Mis manos se congelan.
				HateBiome: ¡Quiero vivir en otro lado! Esto es horrible.
				LikeNPC: "{NPCName} Entiende la importancia del trabajo duro. Es bueno tenerlo cercas."
				LikeNPC_Princess: Tengo que visitar a {NPCName} algun dia, !es bueno tener a una chica que me entiende!
				LoveNPC: "{NPCName} !ya esta aqui¡ ¿Quién es el niño de papá?"
				DislikeNPC: No creo poder concentrarme cuando {NPCName} está cerca. No deja de burlarse de mi.
				HateNPC: Entre nosotros. ¿Alguna vez has pensado en devolver a {NPCName} al lugar donde lo encontraste?
			}

			Brewer: {
				Content: !Me siento Bien!
				NoHome: ¿Tienes alguna vivienda de repuesto? es realmente incomodo hacer pociones sin un techo sobre mi cabeza.
				LoveSpace: Paz y tranquilidad me permiten disfrutar a lo grande!
				FarFromHome: Creo que mi casa estaba por ahi... A menos que me estes llevando a algun lado
				DislikeCrowded: Cuantos más, mejor, y todo eso, pero ya empiezo a sentirme un poco apretada.
				HateCrowded: No puedo estirar las piernas y relajarme sin patear a alguien...
				LikeBiome: Aquí hace un poco de calor, pero el aire es perfecto.
				LoveBiome: !Calidez y tranquilidad, Justo lo que necesito!
				DislikeBiome: Hace mucho frio aqui... Mis manos se congelan.
				HateBiome: ¡Quiero vivir en otro lado! Esto es horrible.
				LikeNPC: «¡Es tan fácil burlarse de {NPCName}! No puedo evitarlo...»
				LikeNPC_Princess: Tengo que volver a visitar a {NPCName} algún día, ¡hay una chica que me entiende!
				LoveNPC: "¡{NPCName} ya llegó! ¿Quién es el niñito de mamá?"
				DislikeNPC: "{NPCName} es tan molesto con sus advertencias constantes. Apenas lo soporto."
				HateNPC: Entre nosotros. ¿Alguna vez has pensado en devolver a {NPCName} al lugar donde lo encontraste?
			}

			Jeweler: {
				Content: !Me siento Bien!
				NoHome: ¿Tienes algún lugar donde pueda quedarme? Es muy incómodo hacer joyas sin un techo sobre mi cabeza.
				LoveSpace: Paz y tranquilidad me permiten disfrutar a lo grande!
				FarFromHome: Creo que mi casa estaba por ahi... A menos que me estes llevando a algun lado
				DislikeCrowded: Cuantos más, mejor, y todo eso, pero ya empiezo a sentirme un poco apretada.
				HateCrowded: No puedo estirar las piernas y relajarme sin patear a alguien...
				LikeBiome: Aquí hace un poco de calor, pero el aire es perfecto.
				LoveBiome: !Calidez y tranquilidad, Justo lo que necesito!
				DislikeBiome: Hace mucho frio aqui... Mis manos se congelan.
				HateBiome: ¡Quiero vivir en otro lado! Esto es horrible.
				LikeNPC: "{NPCName} tiene olfato para el dinero. Es un poco codicioso, pero lo entiendo perfectamente."
				LikeNPC_Princess: Tengo que volver a visitar a {NPCName} algún día, ¡hay una chica que me entiende!
				LoveNPC: "¡{NPCName} ya está aquí! Se nota claramente que somos casi iguales. Aunque no quiero dejarme crecer la barba."
				DislikeNPC: No soporto a las chicas como {NPCName}, me distrae totalmente y me hace perder la concentración.
				HateNPC: Entre nosotros. ¿Alguna vez has pensado en devolver a {NPCName} al lugar donde lo encontraste?
			}

			Musician: {
				Content: !Me siento Bien!
				NoHome: ¿Tienes algún lugar donde pueda quedarme? Es muy incómodo hacer Música sin un techo sobre mi cabeza.
				LoveSpace: Paz y tranquilidad me permiten disfrutar a lo grande!
				FarFromHome: Creo que mi casa estaba por ahi... A menos que me estes llevando a algun lado
				DislikeCrowded: Cuantos más, mejor, y todo eso, pero ya empiezo a sentirme un poco apretada.
				HateCrowded: No puedo estirar las piernas y relajarme sin patear a alguien...
				LikeBiome: Silencio y paz, ¿qué más necesito para hacer música? ¡Y la acústica aquí es increíble!
				LoveBiome: Me encanta lo reluciente y luminoso que es este lugar. Además, es perfecto para fiestas.
				DislikeBiome: Hace demasiado frío aquí... Se me están congelando las manos.
				HateBiome: ¡Quiero vivir en otro lado! Esto es horrible.
				LikeNPC: "{NPCName} me ayuda mucho cuando me quedo sin cajas de música. ¿Sabes lo difícil que es hacerlas?"
				LikeNPC_Princess: Tengo que volver a visitar a {NPCName} algún día, ¡hay una chica que me entiende!
				LoveNPC: "¡A {NPCName} le gusta la música tanto como a mí! Podría pasar todo el día con ella."
				DislikeNPC: Este tacaño de {NPCName} es tan molesto. ¿Podrías sacarlo de aquí?
				HateNPC: Entre nosotros. ¿Alguna vez has pensado en devolver a {NPCName} al lugar donde lo encontraste?
			}

			Operator: {
				Content: !Me siento Bien!
				NoHome: Necesito un refugio. No me gusta estar sin un techo sobre mi cabeza.
				LoveSpace: Paz y tranquilidad me permiten disfrutar a lo grande!
				FarFromHome: Creo que mi casa estaba por ahi... A menos que me estes llevando a algun lado
				DislikeCrowded: Cuantos más, mejor, y todo eso, pero ya empiezo a sentirme un poco apretada.
				HateCrowded: No puedo estirar las piernas y relajarme sin patear a alguien...
				LikeBiome: El océano. Es lo que quería ver. Gracias.
				LoveBiome: Mis circuitos funcionan perfectamente aquí. Sorprendentemente. Me gusta la nieve.
				DislikeBiome: Odio el subsuelo. Lo sabes, ¿verdad?
				HateBiome: ¡Quiero vivir en otro lado! Esto es horrible.
				LikeNPC: "{NPCName} es una de las muchas personas con las que podría hablar sobre la tecnología."
				LikeNPC_Princess: Tengo que volver a visitar a {NPCName} algún día, ¡hay una chica que me entiende!
				LoveNPC: "{NPCName} probablemente sea la única persona que puede entenderme. Al ser un cyborg."
				DislikeNPC: "{NPCName} parece tenerme miedo. Me pregunto por qué, pero su miedo me molesta un poco."
				HateNPC: Entre nosotros. ¿Alguna vez has pensado en devolver a {NPCName} al lugar donde lo encontraste?
			}

			Architect: {
				Content: !Me siento Bien!
				NoHome: Como arquitecto, lo que menos me gusta es NO tener casa.
				LoveSpace: Paz y tranquilidad me permiten disfrutar a lo grande!
				FarFromHome: Creo que mi casa estaba por ahi... A menos que me estes llevando a algun lado
				DislikeCrowded: Cuantos más, mejor, y todo eso, pero ya empiezo a sentirme un poco apretada.
				HateCrowded: No puedo estirar las piernas y relajarme sin patear a alguien...
				LikeBiome: Es un lugar bastante tranquilo. Me gusta.
				LoveBiome: Tantos colores, tantos materiales de construcción. Perfecto.
				DislikeBiome: Odio sentir frío. Necesito un lugar más cálido.
				HateBiome: ¡Quiero vivir en otro lado! Esto es horrible.
				LikeNPC: "{NPCName} puede que solo sea un duende molesto, pero sabe cómo construir. Eso me merece respeto."
				LikeNPC_Princess: Tengo que volver a visitar a {NPCName} algún día, ¡hay una chica que me entiende!
				LoveNPC: "{NPCName} sabe cómo hacer todos los colores. Lo cual es genial."
				DislikeNPC: "{NPCName} es muy gruñón y odia los colores. Supongo que sería divertido hacer que viviera en Hallow."
				HateNPC: Entre nosotros. ¿Alguna vez has pensado en devolver a {NPCName} al lugar donde lo encontraste?
			}

			Tinkerer: {
				Content: !Me siento Bien!
				NoHome: Hacer accesorios requiere paciencia. Y no podría hacerlo si no tuviera una casa.
				LoveSpace: Paz y tranquilidad me permiten disfrutar a lo grande!
				FarFromHome: Creo que mi casa estaba por ahi... A menos que me estes llevando a algun lado
				DislikeCrowded: Cuantos más, mejor, y todo eso, pero ya empiezo a sentirme un poco apretada.
				HateCrowded: No puedo estirar las piernas y relajarme sin patear a alguien...
				LikeBiome: Un poco de oscuridad, pero puedo vivir totalmente aqui.
				LoveBiome: Mi hermana y yo estamos acostumbrados a vivir en lugares fríos, así que eso no me molesta para nada.
				DislikeBiome: Odio el calor y la arena, así que no, no viviría aquí.
				HateBiome: ¡Quiero vivir en otro lado! Esto es horrible.
				LikeNPC: "{NPCName} es muy amable e inteligente. Eso me merece respeto."
				LikeNPC_Princess: Tengo que volver a visitar a {NPCName} algún día, ¡hay una chica que me entiende!
				LoveNPC: "¿Por fin llegó {NPCName}? ¡Tengo mucho que contarte, hermana mayor!"
				DislikeNPC: No dejes que {NPCName} se acerque a mí. La arena de su ropa siempre atascó mis mecanismos.
				HateNPC: Entre nosotros. ¿Alguna vez has pensado en devolver a {NPCName} al lugar donde lo encontraste?
			}

			YoungBrewer: {
				Content: !Me siento Bien!
				NoHome: No me gusta estar afuera por mucho tiempo. Necesito una habitación para mí solo.
				LoveSpace: Paz y tranquilidad me permiten disfrutar a lo grande!
				FarFromHome: Creo que mi casa estaba por ahi... A menos que me estes llevando a algun lado
				DislikeCrowded: Cuantos más, mejor, y todo eso, pero ya empiezo a sentirme un poco apretada.
				HateCrowded: No puedo estirar las piernas y relajarme sin patear a alguien...
				LikeBiome: Puedo vivir cuando hace un poco de calor, así que eso me parece bien.
				LoveBiome: ¡Me encanta el bosque! El aire fresco y todo ese verde a mi alrededor. ¿Qué más podría necesitar una persona?
				DislikeBiome: No me gusta esto. Quiero vivir en un lugar más cálido.
				HateBiome: ¡Quiero vivir en otro lado! Esto es horrible.
				LikeNPC: ¿Papá también está aquí? A veces puede ser un poco tonto, pero mamá lo respeta por sus pociones de teletransporte. Por más que lo intentó, no logró recrearlas.
				LikeNPC_Princess: Tengo que ir a ver a {NPCName}. A ella le encanta jugar conmigo. Y a mí también.
				LoveNPC: ¿Mamá está aquí? ¡Genial! Me gusta mi papá, sí, pero mamá... ¡Sus pociones pueden hacer casi todo y son lo más útiles!
				DislikeNPC: "{NPCName} es muy gruñón. Le he preguntado varias veces si podríamos hacer un juguete, pero SIEMPRE dice que no tiene tiempo para eso."
				HateNPC: Entre nosotros. ¿Alguna vez has pensado en devolver a {NPCName} al lugar donde lo encontraste?
			}
		}

		Buffs: {
			BattleComb: {
				DisplayName: Combinación de batalla
				Description: Combinación de las mejoras, Fuerza vital, Piel de hierro, Regeneración, Rabia e ira 
			}

			Blurring: {
				DisplayName: Desenfoque
				Description: Los enemigos no te pueden ver con claridad (Protección Sagrada durante 10 segundos con un tiempo de recarga de 30 segundos)
			}

			BuilderComb: {
				DisplayName: Combinación constructora
				Description: Combinación de mejoras de construcción, minería y calma
			}

			CalamityComb: {
				DisplayName: Combinación de calamidades
				Description: Combinación de fotositesis, Fabsol's Vodka, Vuelo y salto
			}

			Corrosion: {
				DisplayName: Corrosion
				Description: !Tu carne se está derritiendo!
			}

			DiscordBuff: {
				DisplayName: Discordia
				Description:
					'''
					Te puedes teletransportar a la posicion del cursosr usando hotkey 1
					Distorciona al jugador por 1 segundo despues del teletransporte
					Inflije mucho daño si tienes el estado del caos
					El tiempo del estado de caos se incrementa a 10 segundos
					'''
			}

			Excavation: {
				DisplayName: Excavación
				Description: Las capacidades mineras aumentaron considerablemente
			}

			ExplorerComb: {
				DisplayName: Combinación Exploradora
				Description:
					'''
					Combinación de las mejoras de Sentido el peligro, Cazador, Espeleologo, vision nocturna, Brillo y Mineria
                    También otorga los efectos de Branquias, Aletas y las pociones de Flotación
					'''
			}

			FishingComb: {
				DisplayName: Combinación de pesca
				Description:
					'''
				Combinación de las mejoras Caja, Sonar, Pesca, Regeneración, Espinas, Piel de hierro, Calma y Infierno
					Haz click derecho para habilitar/Deshabilitar el efecto de calma.
					'''
			}

			Fortitude: {
				DisplayName: Fortaleza
				Description: No te pueden derribar
			}

			GreaterDangersense: {
				DisplayName: Mayor sentido del peligro
				Description: Ilumina los proyectiles enemigos.
			}

			LongInvincible: {
				DisplayName: Mayor invensibilidad
				Description: Incrementa el tiempo de invensibilidad
			}

			MageComb: {
				DisplayName: Combinación de mago
				Description: Combinación de las mejoras Poder magico, Regeneración de mana, Clarividencia, Ira y Rabia 
			}

			NinjaSkill: {
				DisplayName: Ninja
				Description: !Eres un nija de verdad!
			}

			RangerComb: {
				DisplayName: Combinación de rango
				Description: Combinación de las Arquero, Reserva de municion, Ira, Rabia 
			}

			StationUltimaBuff: {
				DisplayName: Estación Ultima
				Description: Aplica los efectos de todas las estaciones al mismo tiempo
			}

			SummonerComb: {
				DisplayName: Combinación de invicador
				Description: Combinación de las mejoras de «Convocación», «Hechizado» y «Ira»
			}

			Sunshine: {
				DisplayName: Rayo solar
				Description: Estás generando luz como un Sol en miniatura
			}

			TankComb: {
				DisplayName: Combinación tanque (w/Modded)
				Description: Combinación de las mejoras Rapidez, Resistencia, Fuerza vital, Piel de hierro, Piel de obsidiana, Esoinas, Regeneración, Piel de titan, Invencibilidad
			}

			TitanSkin: {
				DisplayName: Piel de titan
				Description: Tienes cierta inmunidad a las desventajas graves
			}

			TrapsBuff: {
				DisplayName: Mejora de trampas
				Description: Las trampas reciben una mejora
			}

			TrueDiscordBuff: {
				DisplayName: Discordia verdadera
				Description:
					'''
					Puedes teletransportarte a la posición del cursor usando la hotkey
					Se comporta Exactamente como la bara de la discordia
					'''
			}

			UniversalComb: {
				DisplayName: Combinación Universal
				Description: La combinación perfecta entre tanque, mago, arquero y invocador
			}

			VanTankComb: {
				DisplayName: Combinación de tanque (Vanilla)
				Description: Combinación de las mejoras Rapidez, Resistencia, Fuerza viatl, Piel de hierro, Piel de obsidiana, Espinas y Regeneración 
			}

			ThoriumComb: {
				DisplayName: Combinación de Thorium
				Description: Combinación de pociones de Asesino, Sangre, Frenesí, Brillo, Sagrada, Creatividad, Melodía pegajosa, Alcance de la inspiración e Hidratación
            }
		}

		Items: {
			BattleCombination: {
				DisplayName: Combinación de batalla
				Tooltip: Otorga mejoras, que son necesarias para la batalla (Resistencia, Fuerza vital, Piel de hierro, Regeneración, Furia e Ira)
			}

			BeachTeleporterPotion: {
				DisplayName: Poción de teletransporte a la playa
				Tooltip:
					'''
					Teletransportate a la playa
					El lado depende de donde se utilice el cursor
					'''
			}

			BewitchingPotion: {
				DisplayName: Poción encantadora
				Tooltip:
					'''
					Otorga el Beneficio embrujado (Incrementa el numero de invocaciones maximas)
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			BlurringPotion: {
				DisplayName: Poción de difuminación
				Tooltip:
					'''
					Otorga el Beneficio difuminación (Activa el esquive de las sombras por 10 segundos despues 30 segundos de recarga)
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			BuilderCombination: {
				DisplayName: Combinación constructora
				Tooltip: Otorga las mejoras, Para la construcción (Calma, Constructor, Minera)
			}

			CalamityCombination: {
				DisplayName: combinación de calamidad
				Tooltip: Otorga las mejoras de Calamity mod (fotositesis, Fabsol's Vodka, Vuelo y Salto)
			}

			DiscordPotion: {
				DisplayName: Discordia
				Tooltip:
					'''
					Te puedes teletransportar a la posicion del cursosr usando hotkey 1
					Distorciona al jugador por 1 segundo despues del teletransporte
					Inflije mucho daño si tienes el estado del caos
					El tiempo del estado de caos se incrementa a 10 segundos
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			Dopamine: {
				DisplayName: Dopamina
				Tooltip:
					'''
					Te hace feliz
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			DungeonTeleportationPotion: {
				DisplayName: Poción de teletrasporte a la mazmorra
				Tooltip: Te teletransporta a la entrada de la mazmorra
			}

			ExcavationPotion: {
				DisplayName: Poción de excavacion
				Tooltip:
					'''
					Expande tu area de mineria en un solo bloque de 3x3.
					Click derecho en la mejora para cambiar el area de minado de 1x1 y 3x3.
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			ExplorerCombination: {
				DisplayName: Combinación de explorador
				Tooltip: Otorga las mejoras necesarias para explorar (Sentido de,l peligro, Cazador, Espeleologo, Vision nocturna, Brillo, Minera, Branquias, Aletas, Flotación)
			}

			FishingCombination: {
				DisplayName: Combinación de pesca
				Tooltip:
					'''
					Otorga la mejora de Caja, Sonar, Pesca, Regeneración, Espinas, Piel de hierro, Calma y Infierno
					Haz clic con el botón derecho para activar o desactivar el efecto relajante.
					'''
			}

			FortitudePotion: {
				DisplayName: Poción de Fortaleza
				Tooltip:
					'''
					Otorga inmunidad al retroceso
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			GreaterDangersensePotion: {
				DisplayName: Poción del sentido del peligro mejorado
				Tooltip:
					'''
					Otorga una mejora del sentido del peligro (Los proyectiles enemigos brillan)
					Algunos proyectiles enemigos pueden volverse invisibles (por ejemplo Moon Lord's) Usalo con cuidado
					Este efecto es global para los jugadores
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			InvincibilityPotion: {
				DisplayName: Poción de invencibilidad
				Tooltip:
					'''
					Incrementa la invencibilidad despues de recibir daño
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			JungleTeleporterPotion: {
				DisplayName: Pocion de teletransporte a la jungla
				Tooltip:
					'''
					Teletransportate directamente a la jungla
					Click izquierdo para teletransportarte a la jungla
					Click derecho para teletransportarte al arbol de caoba viviente
					'''
			}

			MageCombination: {
				DisplayName: Combinación de magos
				Tooltip: Mejoras de habilidades, que son necesarias para los magos (Poder mágico, Regeneración de maná, Clarividencia, Ira, Furia)
			}

			AlchemistCharmTier1: {
				DisplayName: Amuleto de alquimista, Nivel 1 
				Tooltip:
					'''
					Mientras tengas esto en tu inventario, tienes una probabilidad baja de no consumir la poción
					Alchemist, El Cervecero y joven Cervecero ofrecen un descuento del 10%
					La duración de los efectos positivos es un 10% mayor
					'''
			}

			AlchemistCharmTier2: {
				DisplayName: Amuleto de alquimista, nivel 2
				Tooltip:
					'''
					Mientras tengas esto en tu inventario, tienes una probabilidad moderada de no consumir la poción
					Permite usar pociones de la Hucha mediante Quick Buff
					Alchemist, El Cervecero y joven Cervecero ofrecen un descuento del 25%
					La duración de los beneficios es un 25% mayor
					'''
			}

			AlchemistCharmTier3: {
				DisplayName: Amuleto de alquimista, nivel 3
				Tooltip:
					'''
					Mientras tengas esto en tu inventario, tienes una probabilidad Alta de no consumir la poción
					Permite usar pociones de la Hucha mediante Quick Buff
					Alchemist, El Cervecero y Joven Cervecero ofrecen un descuento del 35%
					La duración de los beneficios es un 35% mayor
					'''
			}

			AlchemistCharmTier4: {
				DisplayName: Amuleto de alquimista, nivel 4
				Tooltip:
					'''
					Mientras tengas esto en tu inventario, tienes una probabilidad Muy Alta de no consumir la poción
					Permite usar pociones de la Hucha mediante Quick Buff
					Alchemist, El Cervecero y Joven Cervecero ofrecen un descuento del 50%
					Hace que las pociones no sean consumibles si se derrota a Calamitas Supremo
					La duración de los beneficios es un 50% mayor
					'''
			}

			GlobalTeleporter: {
				DisplayName: Deformador de mundos
				Tooltip:
					'''
					Te teletransporta a cualquier punto del mapa 
					Usa click derecho en el mapa para teletransportarte 
					No funciona si un jefe esta vivo 
					Se rompe despues de usarlo 
					"O, la justicia azure, el amor carmesi,
					En nombre de aquel destino sepultado,
					Hare un juramento a la luz,
					que les mostraremos a aquellos que
					Frente a nosotros - el poder del amor!"
					'''
			}

			GlobalTeleporterUp: {
				DisplayName: Deformador de mundos modificado
				Tooltip:
					'''
					Te teletransporta a cualquier punto del mapa 
					Usa click derecho en el mapa para teletransportarte 
					No funciona si un jefe esta vivo 
					No se rompe despues de usarlo 
					"O, la justicia azure, el amor carmesi,
					En nombre de aquel destino sepultado,
					Hare un juramento a la luz,
					que les mostraremos a aquellos que
					Frente a nosotros - el poder del amor!"
					'''
			}

			WorldControlUnit: {
				DisplayName: Unidad de control de simulacion
				Tooltip:
					'''
					Producto exclusivo, diseñado por Angela
					Click izquierdo para calmbiar entre el dia y la noche 
					Click derecho para activar o desacrivar la lluvia (Tormeta de arena en el desierto)
					'''
			}

			LuckCharm: {
				DisplayName: Amuleto de la suerte
				Tooltip:
					'''
					Mientras tengas este amuleton en tu inventario, tienes una mejor chance de tener mejores reforjamientos
					Esto no afecta a los accesorios 
					'''
			}

			LuckCharmT2: {
				DisplayName: Amuleto de la suerte absoluta
				Tooltip:
					'''
					Mientras tengas este amuleton en tu inventario, tienes una mejor chance de tener mejores reforjamientos
					También afecta a los accesorios (Amenazante → Afortunado → Protector)
					'''
			}

			MorePotionsCombination: {
				DisplayName: Más combinaciones de pociones
				Tooltip:
					'''
					Otorga la mayoría de los beneficios de Más pociones *pociones
					Sequías, Regeneración mejorada, Valentía, Vínculo espiritual, Piel de diamante, Crepúsculo, Amanecer, Manos ágiles, Velocidad
					'''
			}

			NatureBlessingPotion: {
				DisplayName: Poción de bendicion de la naturaleza
				Tooltip: Otorga la bendicion de la driada 
			}

			NinjaPotion: {
				DisplayName: Poción de ninja
				Tooltip:
					'''
					Incrementa el daño y la probabilidad de critico en un 5%
					Tienes una probabilidad de esquivar los ataques y puedes escalar las paredes
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			InformatingNote: {
				DisplayName: Nota informativa
				Tooltip:
					'''
					Aún no hay bolsas de tesoros disponibles.
					Vence a Skeletron para desbloquear la primera oleada.
					'''
			}

			OceanTeleporterPotion: {
				DisplayName: Poción del teletransportador oceánico
				Tooltip:
					'''
					Te teletransporta al océano (cerca del coral más a la izquierda o más a la derecha)
					El lado depende del botón del mouse que se utilice
					No te teletransportará a ningún lado si no hay corales.
					'''
			}

			PerfectDiscordPotion: {
				DisplayName: Poción de la Discordia Perfecta
				Tooltip:
					'''
					[c/00FF00:Poción única del explorador]
					Permite teletransportarse a la posición del cursor mediante una tecla de acceso rápido
					Se comporta exactamente igual que la Vara de la Discordia
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			HMCraftPound: {
				DisplayName: Excelente libra de artesanía
				Tooltip:
					'''
					Ahora puedes hacer las mejores cosas
					Se puede colocar como una estacion de trabajo
					'''
			}

			MateriaTransmutator: {
				DisplayName: Transmutador de materiaa
				Tooltip:
					'''
					Misma funcionalidad que la mayoría de las estaciones de crafteo en una sola.
					Todas las estaciones de crafteo incluidas :)
					También funciona como fuente de agua, miel y lava.
					'''
			}

			PreHMPenny: {
				DisplayName: Moneda de manualidades sencillas
				Tooltip:
					'''
					Te hace parecer un maestro de la carpintería.
					Se puede colocar como una estacion de trabajo
					'''
			}

			SpecCraftPoint: {
				DisplayName: Punto de fabricación especial
				Tooltip:
					'''
					Has demostrado que puedes hacer cualquier cosa con cualquier material.
					Se puede colocar como una estacion de trabajo
					'''
			}

			RangerCombination: {
				DisplayName: Combinación Ranger
				Tooltip: Mejoras de habilidades, que son necesarias para los Rangers (Tiro con arco, Reserva de munición, Ira, Furia)
			}

			SpiritCombination: {
				DisplayName: Combinación de espíritus
				Tooltip: Otorga la mayoría de los beneficios de las pociones de modificación de espíritu (Runescribe, Soulguard, Spirit, Starburn, Steadfast y Toxin)
			}

			SummonerCombination: {
				DisplayName: Combinación de invocadores
				Tooltip: Otorga mejoras, que son necesarias para los Invocadores (Invocación, Hechizado, Ira)
			}

			AlchemistHorcrux: {
				DisplayName: Horcrux de la alquimista
				Tooltip: En su interior se encuentra un fragmento del alma del Alquimista.
			}

			APMC: {
				DisplayName: Programación de IA y chip de memoria
				Tooltip: Es la copia de seguridad de Ángela.
			}

			ArchitectHorcrux: {
				DisplayName: Horcrux del arquitecto
				Tooltip: En su interior se encuentra un fragmento del alma del arquitecto.
			}

			BrewerHorcrux: {
				DisplayName: Horcrux del El Cervecero
				Tooltip: Tooltip: En su interior se encuentra un fragmento del alma de El Cervecero.
			}

			HorrifyingSkull: {
				DisplayName: Cráneo espeluznante
				Tooltip:
					'''
					Convoca al enemigo más poderoso
					Usar con extremo cuidado 
					'''
			}

			JewelerHorcrux: {
				DisplayName: Horcrux del joyero
				Tooltip: En su interior se encuentra un fragmento del alma del joyero.
			}

			MusicianHorcrux: {
				DisplayName: Horcrux del musico
				Tooltip: The piece of Musician's soul is inside it.
			}

			TinkererHorcrux: {
				DisplayName: Tinkerer Horcrux
				Tooltip: En su interior se encuentra un fragmento del alma del musico.
			}

			SunshinePotion: {
				DisplayName: Poción de sol
				Tooltip:
					'''
					Incrementa el radio de luz generado 
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			TankCombination: {
				DisplayName: Combinación de tanques (con modificaciones)
				Tooltip: Mejoras de habilidades, que son necesarias para los tanques (Rapidez, Resistencia, Fuerza vital, Piel de hierro, Piel de obsidiana, Espinas, Regeneración, Piel de titán, Invencibilidad)
			}

			TempleTeleportationPotion: {
				DisplayName: Poción de teletransporte al templo
				Tooltip: Teletransportate al templo de la jungla
			}

			ThoriumCombination: {
				DisplayName: Combinación de Thorium
				Tooltip:
					'''
					Otorga la mayoría de los beneficios de las pociones del mod Thorium
					Asesino, Sangre, Frenesí, Creatividad, Melodía pegajosa, Alcance inspirador, Resplandeciente, Sagrado, Hidratación
					'''
			}

			TitanSkinPotion: {
				DisplayName: Poción de piel de titán
				Tooltip:
					'''
					Otorga inmunidad a algunos efectos negativos (¡En llamas!, Quemadura por hielo, Llama maldita, Congelado, Helado, Ícor)
					ILa habilidad «Comunidad» de Llama maldita e Ichor solo funcionaría después de derrotar a los Gemelos
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			TrapsPotion: {
				DisplayName: Poción del cazador
				Tooltip:
					'''
					Activa todas las trampas
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			UltimaCake: {
				DisplayName: Pastel ultimo
				Tooltip:
					'''
					Permite aplicar efectos especiales en casi todas las estaciones al mismo tiempo
					Esto incluye fogatas, lámparas, la estatua de Bast, la estación de afilado, la caja de municiones, la bola de cristal, una rebanada de pastel y la mesa encantada.
					Por alguna magia inimaginable, nunca se consumirá
					POCIÓN DE REFUERZO SIN CALAMIDAD
					'''
			}

			UnderworldTeleportationPotion: {
				DisplayName: Poción de teletransporte al inframundo
				Tooltip:
					'''
					Te teletransporta al Inframundo, a la Torre de Obsidiana más a la izquierda o más a la derecha
					El lado depende del botón del mouse que se utilice
					Sería útil tomar la poción de «Piel de Obsidiana» antes de beber eso
					'''
			}

			UniversalCombination: {
				DisplayName: Combinación universal
				Tooltip: Ofrece los efectos combinados de las combinaciones de tanque, guardabosques, mago y invocador en una sola mejora.
			}

			VanTankCombination: {
				DisplayName: Combinación de tanques (Vanilla)
				Tooltip: Mejoras de habilidades, que son necesarias para los tanques (Rapidez, Resistencia, Fuerza vital, Piel de hierro, Piel de obsidiana, Espinas, Regeneración)
			}

			MateriaTransmutatorMK2: {
				DisplayName: Transmutador de Materia MK 2
				Tooltip: Transmutador de Materia MK 2
			}

			SingleUseCellphone: {
				Tooltip: Se busca comerciante ambulante. Solo se puede utilizar durante el día.
				DisplayName: Celular de un solo uso
			}
		}

