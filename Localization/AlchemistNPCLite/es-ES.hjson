		"Keybinds.Discord Buff Teleportation.DisplayName": Mejora de teletransportacion de Discordia

		Configs: {
			ModConfiguration: {
				ShopChangeDelay: {
					Tooltip: El retraso antes de que se pueda cambiar de tienda se puede modificar tras abrir la interfaz. El valor predeterminado es de 10 fotogramas.
					Label: Retraso en el cambio de tienda
				}

				DesertFossilPrice: {
					Tooltip: El precio predeterminado de la plata es de 10 por 1000
					Label: Desert Fossil Price
				}

				SiltSlushPrice: {
					Tooltip: El precio predeterminado de la plata es 700 por 7.
					Label: Precio de los bloques de limo/nieve derretida
				}

				WormholePrice: {
					Tooltip: El precio predeterminado de la plata es de 10 por 1000
					Label: Precio de la poción del agujero de gusano
				}

				RecallPrice: {
					Tooltip: El precio predeterminado de la plata es de 10 por 1000.
					Label: Precio de la poción de recuperación
				}

				StarPrice: {
					Tooltip: El precio predeterminado de la plata es de 10 por 1000.
					Label: Precio de Estrella caida
				}

				PotsPriceMulti: {
					Tooltip: Multiplica el precio de las pociones por X. El valor predeterminado es 1.
					Label: Multiplicador de precio de pociones
				}

				CatchNPC: {
					Tooltip: Si se activa esta opción, los NPC de la ciudad del mod se pueden atrapar. Activada por defecto.
					Label: Opción para activar o desactivar los NPC del mod «Catcheable»
				}

				ModItems: {
					Tooltip: Si se activa, permite que existan los objetos y pociones personalizados de los mods (poción de desenfoque, World Warper, etc.). Está activado por defecto. Requiere que los mods se actualicen para que la información se refleje.
					Label: Botón para activar o desactivar los elementos personalizados del mod
				}

				RevPrices: {
					Tooltip: Verdadero para aumentar los precios de las pociones. Verdadero por defecto
					Label: Escalado de precios en el modo Revengeance
				}

				DisabledLocatorNpcs: {
					Tooltip: Las flechas no apuntarán a estos NPCs
					Label: NPC desactivados para el localizador del analizador de formas de vida
				}

				LocatorRange: {
					Tooltip: Distancia máxima que seguirá el puntero. 4000 por defecto
					Label: Rango de detección del analizador de formas de vida
				}

				LifeformAnalyzer: {
					Tooltip: Activa o desactiva el puntero láser del Analizador de formas de vida (parpadea cada segundo). El valor predeterminado es «True».
					Label: Puntero láser del Lifeform Analyzer
				}

				TinkererSpawn: {
					Tooltip: True para habilitar la aparición del NPC Tinkerer, false para deshabilitarla. El valor predeterminado es True.
					Label: Activar/desactivar la aparición del Tinkerer
				}

				MusicianSpawn: {
					Tooltip: True para habilitar la aparición de NPC músicos; false para deshabilitarla. El valor predeterminado es True.
					Label: Músico: Mostrar/Ocultar
				}

				OperatorSpawn: {
					Tooltip: True para habilitar la aparición del NPC Operador; false para deshabilitarla. El valor predeterminado es True.
					Label: Alternar aparición del operador
				}

				ArchitectSpawn: {
					Tooltip: True para habilitar la aparición del NPC Arquitecto; false para deshabilitarla. El valor predeterminado es True.
					Label: Activar/desactivar Spawn de arquitecto
				}

				YoungBrewerSpawn: {
					Tooltip: Verdadero para habilitar la aparición del NPC Joven cervecero, falso para deshabilitarla. Verdadero por defecto
					Label: Alternar spawn de joven cervecero
				}

				JewelerSpawn: {
					Tooltip: True para habilitar la aparición del NPC joyero, false para deshabilitarla. El valor predeterminado es True.
					Label: Alternar spawn de joyero
				}

				BrewerSpawn: {
					Tooltip: Verdadero para habilitar la aparición del NPC Cervecero, falso para deshabilitarla. Verdadero por defecto
					Label: Alternar el spawn del cervecero
				}

				AlchemistSpawn: {
					Tooltip: Verdadero para habilitar la aparición del NPC Alquimista, falso para deshabilitarla. Verdadero por defecto
					Label: Alternar el spawn del Alquimista
				}

				DisplayName: Configuracion del mod

				LifeformAnalyzerAlt: {
					Label: Textura alternativa para el localizador del Analizador de formas de vida
					Tooltip: Utiliza una textura alternativa para el marcador del Analizador de formas de vida. Desactivado por defecto
				}
			}
		}
	}
