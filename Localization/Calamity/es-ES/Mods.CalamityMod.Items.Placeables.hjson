CorruptionEffigy: {
	DisplayName: Efigie de Corrupción
	Tooltip:
		'''
		<right> al colocarla para obtener un {0}% de aumento en la velocidad de movimiento y probabilidad de ataque crítico
		Sin embargo, esto conlleva un costo del {1}% de reducción de daño
		Esto no se puede acumular con la Efigie Carmesí
		'''
	SalesPitch: "{$Common.SalesmanShrinePitch}"
}

AltarOfTheAccursedItem: {
	DisplayName: Altar de los Malditos
	Tooltip:
		'''
		Ofrece [i:CalamityMod/AshesofCalamity] {$Items.Materials.AshesofCalamity.DisplayName} en este altar para invocar a la Bruja
		Hacerlo creará una arena cuadrada, con el altar en el centro
		La Bruja se enfurece mientras estás fuera de la arena
		Pasar el cursor sobre el altar mientras se usa la regla mostrará un recuadro de arena temporal
		{$CommonItemTooltip.SpecialCrafting}
		'''
}

