CalamityCanvas2023: {
	DisplayName: Lienzo de Calamity 2023
	Tooltip:
		'''
		<right> al colocarlo para abrir una IU que permite personalizar el enfoque de la pintura
		<left> para hacer que el enfoque siga al cursor, <left> de nuevo para fijarlo
		También se pueden usar las teclas de flecha para ajustar manualmente el punto de enfoque
		La rueda del ratón acerca y aleja el enfoque
		Mantén Shift para ocultar la IU sin cerrarla
		'Abraza el caos'
		'''
}

