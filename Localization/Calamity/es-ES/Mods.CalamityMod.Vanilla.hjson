	ArmorPenStat: +{0} de penetración de armadura
	CritStat: +{0}% de probabilidad de golpe crítico
	DamageStat: +{0}% de daño
	DefenseStat: +{0} de defensa
	DRStat: +{0}% de reducción de daño
	LuckStat: +{0} de suerte
	MeleeSpeedStat: +{0}% de velocidad de combate cuerpo a cuerpo
	SpeedStat: +{0}% de velocidad de movimiento
}

EditedTooltip: {
	/*
	Boss Summons
	*/
	Abeemination:
		'''
		Invoca a la Reina Abeja cuando se usa en la Jungla
		Se enfurecerá fuera de la Jungla Subterránea
		'''
	BloodySpine:
		'''
		Invoca al Cerebro de Cthulhu cuando se usa en el Crímson
		Desaparece fuera del Crímson
		'''
	ClothierVoodooDoll:
		'''
		Mientras está equipado, invoca al Esqueletrón cuando el Sastre es asesinado durante la noche
		Se enfurecerá durante el día
		'Eres una persona terrible'
		'''
	DeerThing: Invoca a Deerclops cuando se usa en el bioma de Nieve o Hielo
	GuideVoodooDoll:
		'''
		Invoca al Muro carnoso si se lanza a la lava en el Inframundo mientras el Guía está vivo
		'Eres una persona terrible'
		'''
	LihzahrdPowerCell:
		'''
		Invoca al Gólem cuando se usa en el Altar Lihzahrd
		Se enfurecerá fuera del Templo de la Jungla
		'''
	MechanicalEye: Invoca a Los Gemelos cuando se usa durante la noche
	MechanicalSkull:
		'''
		Invoca al Esqueletrón Mayor cuando se usa durante la noche
		Se enfurecerá durante el día
		'''
	MechanicalWorm: Invoca al Destructor cuando se usa durante la noche
	QueenSlimeCrystal: Invoca a la Reina Slime cuando se usa en la Bendición
	SuspiciousLookingEye: Invoca al Ojo de Cthulhu cuando se usa durante la noche
	WormFood:
		'''
		Invoca al Devoramundo cuando se usa en la Corrupción
		Desaparece fuera de la Corrupción
		'''
	/*
	Life Regen
	*/
	Campfires: La regeneración de vida aumenta en 0.5 PV/s al estar cerca de una hoguera
	HeartLantern: Otorga +1 PV/s de regeneración de vida cuando está colocada cerca
	BottledHoney:
		'''
		Otorga +1 PV/s de regeneración de vida por un corto tiempo
		Otorga +1 PV/s adicional de regeneración de vida mientras se está bajo un efecto negativo dañino
		'''
	ShinyStone: Otorga +2 PV/s de regeneración de vida y acelera la regeneración de vida natural cuando no te mueves
	BandofRegeneration: Otorga +1 PV/s de regeneración de vida
	CharmofMyths: Otorga +1 PV/s de regeneración de vida y reduce el tiempo de reutilización de las pociones de curación en un 25%
	RegenerationPotion: Proporciona +2 PV/s de regeneración de vida
	HamBat: Derrotar enemigos otorga temporalmente +3 PV/s de regeneración de vida
	// Vital Crystal
	AegisCrystal: Aumenta permanentemente la regeneración de vida natural
	/*
	OOA armors
	*/
	SquireGreatHelm: Aumenta el número máximo de centinelas en 1 y otorga +2 PV/s de regeneración de vida
	MonkBrows: Aumenta el número máximo de centinelas en 1 y aumenta la velocidad de pícaro en un 20%
	MonkShirt: 20% más de daño de invocación y de pícaro
	MonkPants: 15% más de probabilidad de golpe crítico de pícaro y 20% más de velocidad de movimiento
	// Valhalla Knight
	SquireAltShirt: 30% más de daño de invocación y otorga +4 PV/s de regeneración de vida
	// Shinobi Infiltrator
	MonkAltHead: Aumenta el número máximo de centinelas en 2 y aumenta el daño de invocación y de pícaro en un 20%
	MonkAltShirt0: 20% más de daño de invocación y velocidad de pícaro
	MonkAltShirt1: 5% más de probabilidad de golpe crítico de pícaro
	MonkAltPants: 20% más de daño de invocación y probabilidad de golpe crítico de pícaro
	/*
	Accessories
	*/
	SunMoonStones: probabilidad de golpe crítico, regeneración de vida,
	CelestialStoneShell: Ligero aumento al daño,
	PowerBerserkerGlove: 12% más de velocidad de combate cuerpo a cuerpo, no se acumula con versiones inferiores
	MechanicalGlove:
		'''
		12% más de daño de combate cuerpo a cuerpo
		12% más de velocidad de combate cuerpo a cuerpo, no se acumula con versiones inferiores
		'''
	FireGauntlet1: Aumenta el retroceso de combate cuerpo a cuerpo y los ataques cuerpo a cuerpo infligen Fuego Infernal
	FireGauntlet2:
		'''
		14% más de daño de combate cuerpo a cuerpo
		14% más de velocidad de combate cuerpo a cuerpo, no se acumula con versiones inferiores
		'''
	MoltenQuiver: Enciende las flechas de madera en llamas y todas las flechas infligen Fuego Infernal
	RifleScope1: Aumenta el rango de visión para armas de fuego (<right> para alejar la vista)
	RifleScope2: El efecto de mira se puede activar/desactivar con la visibilidad
	ReconScope1: 15% más de daño a distancia
	SniperScope: 12% más de probabilidad de golpe crítico a distancia
	Magiluminescence:
		'''
		Aumenta la aceleración y desaceleración de movimiento en 1.75x
		Aumenta la velocidad de movimiento en 1.15x. Este bonus se aplica a los accesorios de botas de movimiento
		'''
	FrogLeg: Aumenta la velocidad de salto en un {0}% y permite el salto automático
	// Soaring Insignia
	EmpressFlightBooster1: Aumenta el tiempo de vuelo de alas en un 33%
	EmpressFlightBooster2: Aumenta la velocidad de movimiento en un 7.5%, la velocidad de salto en un 10% y la aceleración en 1.25x
	GravityGlobe:
		'''
		Proporciona un 32% más de velocidad de salto y mayor velocidad de caída
		Proporciona un salto de impulso gravitacional, que se recarga cada vez que la gravedad se invierte
		Mejora ligeramente la velocidad de movimiento aéreo sin alas
		Pulsa {$Key.UP} para cambiar la gravedad
		Pulsa {$Key.DOWN} para caer más rápido
		'''
	FlameWakerBoots:
		'''
		25% más de daño del efecto negativo de Calor
		Todos los ataques prenden fuego a los enemigos
		'Nunca más tengas los pies fríos'
		'''
	/*
	Armor
	*/
	MagicHat: 6% más de probabilidad de golpe crítico mágico
	Gi: 10% más de velocidad de movimiento y salto
	SolarFlarePieces: Otorga +1 PV/s de regeneración de vida
	/*
	Potions
	*/
	ArcheryPotion: 5% más de daño de flecha y 20% más de velocidad de flecha
	AleSake:
		'''
		Aumenta el tamaño del arma cuerpo a cuerpo en un 25%, pero reduce la velocidad cuerpo a cuerpo en un 10%
		Cuenta como alcohol para el Envenenamiento por Alcohol
		{$Common.AlcoholWarning}
		'''
	FlaskofCursedFlames: Los ataques cuerpo a cuerpo, de látigo y de pícaro infligen llamas malditas a los enemigos
	FlaskofFire: Los ataques cuerpo a cuerpo, de látigo y de pícaro prenden fuego a los enemigos
	FlaskofGold: Los ataques cuerpo a cuerpo, de látigo y de pícaro hacen que los enemigos suelten más oro
	FlaskofIchor: Los ataques cuerpo a cuerpo, de látigo y de pícaro reducen la defensa de los enemigos
	FlaskofNanites: Los ataques cuerpo a cuerpo, de látigo y de pícaro confunden a los enemigos
	FlaskofParty: Todos los ataques hacen aparecer confeti
	FlaskofPoison: Los ataques cuerpo a cuerpo, de látigo y de pícaro envenenan a los enemigos
	FlaskofVenom: Los ataques cuerpo a cuerpo, de látigo y de pícaro infligen Veneno Ácido a los enemigos
	/*
	Others
	*/
	// Aerial Bane
	DD2BetsyBow: Dispara una ráfaga compacta de 6 flechas que se dividen
	GoldPickaxe: Puede minar Demonita, Crimsana, Meteorita, Prismas Marinos y Cristales de Prisma Marino
	MasterExclusive: Maestro o Revengeance
	// Sparkle Slime Balloon
	GelBalloon:
		'''
		Lanza una mezcla de slime y cristales brillantes
		Los enemigos enlimados reciben más daño de los efectos negativos basados en fuego
		'''
	// Ancient Manipulator
	LunarCraftingStation: Se usa para fabricar objetos a partir de Fragmentos Lunares, Luminita y Lingotes Astrales
	AnkhShield: Otorga inmunidad a la mayoría de los efectos negativos, incluyendo Viento Fuerte
}

// Buff Descriptions
BuffDescription: {
	Banner: Tienes mayor daño y defensa contra los siguientes:
	BeetleMight: El daño y la velocidad de combate cuerpo a cuerpo aumentan en un {0}% y {1}% respectivamente
	ChaosState: Los teletransportes del Rod of Discord están desactivados
	Rabies: Menor regeneración de vida, provoca efectos de estado
	WeaponImbueConfetti: Todos los ataques hacen aparecer confeti
	WeaponImbueCursedFlames: Los ataques cuerpo a cuerpo, de látigo y de pícaro infligen llamas malditas a los enemigos
	WeaponImbueFire: Los ataques cuerpo a cuerpo, de látigo y de pícaro prenden fuego a los enemigos
	WeaponImbueGold: Los ataques cuerpo a cuerpo, de látigo y de pícaro hacen que los enemigos suelten más oro
	WeaponImbueIchor: Los ataques cuerpo a cuerpo, de látigo y de pícaro reducen la defensa de los enemigos
	WeaponImbueNanites: Los ataques cuerpo a cuerpo, de látigo y de pícaro confunden a los enemigos
	WeaponImbuePoison: Los ataques cuerpo a cuerpo, de látigo y de pícaro envenenan a los enemigos
	WeaponImbueVenom: Los ataques cuerpo a cuerpo, de látigo y de pícaro infligen veneno ácido a tus objetivos
}

