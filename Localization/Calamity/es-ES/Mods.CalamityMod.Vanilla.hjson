	Daybloom: "[C/FFEB8A:Una hierba alegre que florece bajo la luz del día]"
	Moonglow: "[C/8AFFFF:Una hierba radiante que florece bajo la luz de la luna]"
	Waterleaf: "[C/8AFFAF:Una hierba tenaz que florece bajo la lluvia]"
	Blinkroot: "[C/FFC28A:Una hierba caprichosa, cuya floración es impredecible]"
	Shiverthorn: "[C/AADEFA:Una hierba gélida que florece lentamente y de forma permanente]"
	Deathweed: "[C/A98AFF:Una hierba repugnante que florece bajo la Luna Llena o la Luna de Sangre]"
	Fireblossom: "[C/FF8063:Una hierba vibrante que florece en las horas del atardecer]"
}

