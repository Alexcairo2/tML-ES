AddedTooltip: {
	/*
	Accessories
	*/
	TitanGloveLine: 10% más de daño de cuerpo a cuerpo verdadero
	YoyoGlove: Los yoyos secundarios harán un 50% menos de daño
	// Also used by Sniper Scope
	EyeoftheGolem: 15% más de daño de golpe crítico
	RifleScope: El efecto de mira se puede activar/desactivar con la visibilidad
	ReconScope2: 5% más de probabilidad de golpe crítico a distancia
	ArcaneFlower: 5% más de daño mágico
	HellfireTreads:
		'''
		50% más de daño del efecto negativo de Calor, no se acumula con versiones inferiores
		Todos los ataques infligen Fuego Infernal
		'''
	FairyBoots:
		'''
		Las hadas pueden aparecer en cualquier momento en la superficie y aparecen con mucha más frecuencia
		Las hadas cercanas otorgan +1 PV/s de regeneración de vida, 4 de defensa y 10% de velocidad de movimiento
		Las hadas son inmunes al daño y ya no huirán
		'''
	FleshKnucklesLine: La vida máxima aumenta en 25
	HandWarmer: Proporciona un aumento de regeneración al llevar la armadura de Nieve
	/*
	Others
	*/
	TruffleWorm:
		'''
		Invoca a Duke Fishron si se usa como cebo en el Océano
		Se enfurecerá fuera del Océano
		'''
	SlimeGun: Los enemigos enlimados reciben más daño de los efectos negativos basados en fuego
	RodofDiscord: La teletransportación está desactivada mientras el Estado de Caos está activo
	Pwnhammer:
		'''
		Los Altares Demoníacos ahora sueltan Almas de la Noche en lugar de generar minerales al ser destruidos
		Los minerales del Modo Difícil ahora se generan después de derrotar a los Jefes Mecánicos por primera vez
		'''
	// Life Drain
	SoulDrain:
		'''
		Esto otorga +1.5 PV/s de regeneración de vida y acelera la regeneración de vida natural
		El drenaje de vida se acumula según el número de enemigos alcanzados
		'''
	GoldenFishingRod: Su línea de pesca nunca se romperá
	Tombstones:
		'''
		13 lápidas de cualquier tipo convierten el área circundante en un cementerio
		Los cementerios tienen varias ventas y recetas de objetos nuevos
		'''
	FeatherfallPotion: Desactiva toda recuperación de vuelo en el aire
	CrimsonArmorPieces: +0.5 PV/s de regeneración de vida
	Picksaw: Puede minar Mineral de Escoria ubicado en el Abismo
}

PrefixTooltip: {
	ArcaneBuffStat:
		'''
		+{0} de maná máximo
		+{1}% de daño mágico
