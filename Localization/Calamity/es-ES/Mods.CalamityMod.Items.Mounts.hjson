OnyxExcavatorKey: {
	DisplayName: Llave de la Excavadora de Ónice
	Tooltip:
		'''
		Invoca una montura de Taladro de Ónice montable
		Mantén <left> para perforar bloques al moverte horizontal o hacia abajo
		La potencia de pico y la velocidad de minado del taladro copian el mejor pico de tu inventario
		'¿Demoler irresponsablemente toda la generación de mundo tan cuidada causando devastación ecológica descontrolada? Espléndido'
		'''
}

