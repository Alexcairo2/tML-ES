ExoThrone: {
	DisplayName: Caja Exo
	Tooltip:
		'''
		Materializa una Montura Trono Exo voladora bastante cómoda y extremadamente ágil
		Mantén [KEY] mientras estás sentado en el trono para moverte más despacio con mayor precisión
		'Un jugador cómodo es un jugador peligroso'
		'''
}

