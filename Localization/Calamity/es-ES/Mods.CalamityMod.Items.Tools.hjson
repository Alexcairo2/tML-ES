AggressiveVoucher: {
	DisplayName: Vale Agresivo
	Tooltip:
		'''
		Marca este objeto como favorito en tu inventario para aumentar la probabilidad de obtener una reforja deseable
		Este efecto solo se aplica al reforjar accesorios
		Reforja objetivo: {0}
		Reforjas seleccionables: {1}
		[c/aaaaaa:Shift-<right> en tu inventario para alternar entre las reforjas objetivo]
		'''
	SalesPitch:
		'''
		'Ese duende de ahí solo te está estafando para sacarte tu dinero, ¿sabes? ¡Pero no te preocupes, Hoggart y yo tenemos una solución para eso!'
		'¡Solo dale esto y mira cómo martilla tu equipo como si hubiera sido tocado por la inspiración divina! ¡Será como un objeto nuevo!'
		'''
}

