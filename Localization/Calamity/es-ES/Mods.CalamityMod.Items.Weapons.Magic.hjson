}

VividClarity: {
	DisplayName: Claridad Vívida
	Tooltip:
		'''
		Dispara cinco rayos aleatorios de exo-energía hacia el cursor
		Los golpes a enemigos y bloques causan una gran explosión de destello, un láser adicional desde el cielo, o se dividen en orbes de energía
		Los enemigos golpeados son licuados por la [cbuff:CalamityMod/MiracleBlight]
		'Su majestuosidad inspira un destello de genialidad sin igual'
		'''
}

VoidVortex: {
	DisplayName: Vórtice del Vacío
