AstralHelm: {
	DisplayName: Yelmo Astral
	Tooltip:
		'''
		{$CommonItemTooltip.PercentIncreasedDamage} y {$CommonItemTooltip.PercentIncreasedCritChance@1}
		Detecta criaturas cercanas, proyectiles enemigos, fuentes de peligro y tesoros
		[c/aaaaaa:Shift-<right> en tu inventario para activar/desactivar el] [cbuffplr:CalamityMod/Omniscience] [c/aaaaaa:efecto]
		'''
	SetBonus:
		'''
		{$CommonItemTooltip.IncreasesMaxMinionsBy}
		{$CommonItemTooltip.PercentIncreasedDamageCritChance@1}
		Cada vez que asestes un crítico a un enemigo, lloverá una lluvia de estrellas
		Este efecto tiene un tiempo de espera de {2} {^2:segundo;segundos} antes de poder activarse de nuevo
		'''
}

