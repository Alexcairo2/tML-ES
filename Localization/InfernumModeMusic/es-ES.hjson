Mods: {
	InfernumModeMusic: {
		Projectiles.SoulDrivenHeadphonesProj.DisplayName: Auriculares Impulsados por Almas

		Items: {
			SoulDrivenHeadphones: {
				DisplayName: Auriculares Impulsados por Almas
				Tooltip:
					'''
					Te permiten elegir y reproducir música personalizada de Infernum de los jefes derrotados, y alternar un tema especial de batalla contra jefes
					Al sostenerlos, percibes vagamente una presencia mística
					También puedes oír el sonido de instrumentos tocando con pasión
					'''
			}
		}

		HeadphonesText: {
			1: ¡Ahora suena {0}!
			2: ¡{0} sonará durante las peleas contra jefes!
		}

		BossName: {
			// DO NOT change the - to any other symbol or the code that displays "Now playing X" won't work
			TitleScreen: Sky After Rain - Infernum
			KingSlime: Gelatinous Dynasty - Rey Slime
			EyeOfCthulhu: Seer of the Night - El Ojo de Cthulhu
			EaterOfWorlds: Maw of the Corruption - El Devoramundos
			BrainOfCthulhu: Intellect of the Crimson - El Cerebro de Cthulhu
			QueenBee: Royal Retaliation - La Abeja Reina
			Skeletron: Warden of the Damned - Esqueletrón
			WallOfFlesh: One's Ending, Another's Beginning - El Muro Carnoso
			Minibosses: Misanthropic Encounters - Minijefes
			QueenSlime: Crowned before One's End - Reina Slime
			MechBosses: Inferior Fabrications - El Trío Mecánico
			Plantera: Floral Animosity - Plantera
			Golem: Icon of the Sun - Gólem
			DukeFishron: Razorblade Typhoon - Duque Fishron
			EmpressOfLight: Shining Kaleidoscope - La Emperatriz de la Luz
			LunaticCultist: Eidolic Ancestry - El Cultista Lunático
			BereftVassal: Duel for a Lost Kingdom - El Vasallo Despojado
			MoonLord: The End of an Olden Era - El Señor de la Luna
			PrimordialWyrm: Vocitus Terminus - El Gusano Primordial
			ExoMechsOld: Inferior Fabrications (Exo Remix) - Los Exo Mecánicos
			ExoMechs: Catastrophic Fabrications - Los Exo Mecánicos
			ExoMechsAlt: Zenith Fabrications - Los Exo Mecánicos
			Draedon: Their Fabricator - Draedon
			Calamitas: Scars of Calamity - Calamitas
			StormBeforeDawn: Storm Before Dawn - Infernum
		}

		Errors: {
			1: ERROR: No se especificó ningún nombre de función. El primer argumento debe ser un nombre de función.
			2: ERROR: El primer argumento debe ser un nombre de función de tipo cadena.
		}

