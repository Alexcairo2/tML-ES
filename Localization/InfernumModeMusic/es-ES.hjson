				}

				PlayTheirFabricator: {
					Label: Their Fabricator
					Tooltip: Si está activado, sonará Their Fabricator al final de la pelea.
				}

				OverrideCalTheme: {
					Label: Calamitas Suprema
					Tooltip: Si está activado, sonará Scars of Calamity.
				}

				ToggleAllMusic: {
					Label: Alternar todas las sustituciones de música
					Tooltip: Activar esto habilitará todas las sustituciones de música
				}
			}
